{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",

    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "./node_modules/@types",
      "./src/@types"
    ]
  },

  "include": ["src/**/*"]
}